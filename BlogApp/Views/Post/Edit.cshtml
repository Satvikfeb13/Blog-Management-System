@model EditViewModel
@{
    ViewData["Title"] = "Edit Post";
}

<style>
    .content-wrapper {
        padding: 20px;
        max-width: 1000px;
        margin: 0 auto;
        font-family: sans-serif;
    }
</style>

<div class="content-wrapper">

    <div class="row">
        <div class="col-6">
            <h2>@ViewData["Title"]</h2>
        </div>

        <div class="col-6 text-end">
            <a class="btn btn-primary" asp-controller="Post" asp-action="Index">
                Back To List
            </a>
        </div>
    </div>

    <hr />

    <form asp-controller="Post" asp-action="Edit" method="post" enctype="multipart/form-data">

        <div class="validation-summary">
            <div asp-validation-summary="All" class="text-danger"></div>
        </div>

        <input type="hidden" asp-for="Post.Id" />

        <div class="form-group mb-3">
            <label asp-for="Post.Title"></label>
            <input asp-for="Post.Title" class="form-control" />
            <span asp-validation-for="Post.Title" class="text-danger"></span>
        </div>

        <div class="form-group mb-3">
            <label asp-for="Post.CategoryId"></label>
            <select asp-for="Post.CategoryId" asp-items="Model.Categories" class="form-control">
                <option value="">Select Category</option>
            </select>
            <span asp-validation-for="Post.CategoryId" class="text-danger"></span>
        </div>

        <div class="form-group mb-3">
            <label asp-for="Post.Author"></label>
            <input asp-for="Post.Author" class="form-control" />
            <span asp-validation-for="Post.Author" class="text-danger"></span>
        </div>

        <div class="form-group mb-3">
            <label asp-for="Post.Content"></label>
            <textarea asp-for="Post.Content" class="form-control" rows="6"></textarea>
            <span asp-validation-for="Post.Content" class="text-danger"></span>
        </div>

        <div class="form-group mb-3">
            <label asp-for="FeatureImage"></label>
            <input asp-for="FeatureImage" type="file" class="form-control" />
        </div>

        <div>
            <button type="submit" class="btn btn-primary">Update</button>

            <a asp-controller="Post" asp-action="Index" class="btn btn-secondary">
                Back to List
            </a>
        </div>

    </form>

</div>

@section Scripts {

<script src="https://cdn.tiny.cloud/1/6a3cyosgsnqk14ob0unncbyn8k8q0t4cipo3uu83mefda18y/tinymce/8/tinymce.min.js"
        referrerpolicy="origin"
        crossorigin="anonymous"></script>

<script>
    tinymce.init({
        selector: 'textarea',
        height: 300
    });
</script>

}