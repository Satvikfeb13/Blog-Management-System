@model Post

@{
    ViewData["Title"] = " Delete Post";
}

<h2>@ViewData["Title"]<h2/>
    <h4>Do you want to delete the post</h4>
    <form asp-controller="Post" asp-action="DeleteConfirm">
        <input  type="hidden" asp-for="@Model.Id"/>
        <button type="submit" class="btn btn-danger mt-2">Delete</button>
        <a asp-action="Index" asp-controller="Post" class="btn btn-secondary mt-2">Cancel</a>

    </form>